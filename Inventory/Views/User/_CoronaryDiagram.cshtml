<link href="~/css/coronarydiagram.css" rel="stylesheet" />
@* <script type="module" src="~/js/coronarydiagram/index.js"></script> *@
<script type="module" src="~/js/dist/coronarydiagram.bundle.js"></script>
<div id="element-menu" class="context-menu">
    <ul>
        <li data-action="delete">Delete</li>
        <li data-action="add-note">Add Note</li>
    </ul>
</div>
<div id="vertex-menu" class="context-menu">
    <ul>
        <li data-action="delete">Delete vertex</li>
        <li data-action="add-before">Add vertex before</li>
        <li data-action="add-after">Add vertex after</li>
    </ul>
</div>
<div id="link-color-menu" class="context-menu">
    <ul>
        <li>
            Color
            <ul>
                <li data-color="#ff0000">Red</li>
                <li data-color="#00aa00">Green</li>
                <li data-color="#0055ff">Blue</li>
                <li data-color="#000000">Black</li>
            </ul>
        </li>
        <li data-action="hide-label">Hide Labels</li>
        <li data-action="show-label">Show Labels</li>
        <li data-action="add-rectangle">Add Rectangle</li>
        <li data-action="divide-segment">Divide Segment</li>
        <li data-action="add-worm" data-color="#000000">Oclusion</li>
        <li data-action="add-up-bottom-stroke">Stenosis</li>
    </ul>
</div>
<div id="diagramBtncontrols">
    <button id="saveBtn">Save Diagram</button>
    <button id="loadBtn">Load Diagram</button>
    <button id="undoBtn">Undo</button>
    <button id="redoBtn">Redo</button>
</div>
<div id="paper-wrapper">
    <div id="paper">
    </div>
</div>
