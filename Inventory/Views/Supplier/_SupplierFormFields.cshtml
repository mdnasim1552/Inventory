@model InventoryEntity.Supplier.SupplierDto
@{

}
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="Name">Supplier Name</label>
        <input asp-for="Name" type="text" />
    </div>
</div>
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" type="text" readonly="@(ViewBag.DisableInput == true ? "readonly" : null)">
    </div>
</div>
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="PhoneNumber">Phone</label>
        <input asp-for="PhoneNumber" type="text">
    </div>
</div>
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="Country">Country</label>
        <select class="select" asp-for="Country" asp-items="@(new List<SelectListItem> {
                                                                new SelectListItem { Value = "Bangladesh", Text = "Bangladesh" }
                                                            })" required>
            <option value="" selected disabled>-- Choose Country --</option>
        </select>
    </div>
</div>
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="City">City</label>
        <select class="select" asp-for="City" asp-items="@(new List<SelectListItem> {
                                                                 new SelectListItem { Value = "Dhaka", Text = "Dhaka" },
                                                                 new SelectListItem { Value = "Barishal", Text = "Barishal" },
                                                                 new SelectListItem { Value = "Chattogram", Text = "Chattogram" },
                                                                 new SelectListItem { Value = "Khulna", Text = "Khulna" },
                                                                 new SelectListItem { Value = "Rajshahi", Text = "Rajshahi" },
                                                                 new SelectListItem { Value = "Rangpur", Text = "Rangpur" },
                                                                 new SelectListItem { Value = "Mymensingh ", Text = "Mymensingh " },
                                                                 new SelectListItem { Value = "Sylhet ", Text = "Sylhet " }
                                                             })" required>
            <option value="" selected disabled>-- Choose City --</option>
        </select>
    </div>
</div>
<div class="col-lg-9 col-12">
    <div class="form-group">
        <label asp-for="Address">Address</label>
        <input asp-for="Address" type="text">
    </div>
</div>
<div class="col-lg-12">
    <div class="form-group">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>
</div>
<div class="col-lg-12">
    <div class="form-group">
        <label asp-for="SupplierImg"> Supplier Image</label>
        <div class="image-upload" style="position:relative;">
            <input asp-for="SupplierImg" type="file" accept="image/*" id="fileInput" />
            <div class="image-uploads" id="imageuloadContainer">
                <img src="~/assets/img/icons/upload.svg" alt="img" />
                <h4>Drag and drop a file to upload</h4>
            </div>
            <div class="icons-items text-center" id="fileDetails" style="display: none;height: 100px;align-content: center;">
                <span id="fileName"></span><br />
                <span id="fileSize"></span><br />
                <ul class="icons-list" style="list-style-type: none; padding: 0; margin: 0; display: flex; justify-content: center; align-items: center;position:absolute;top:0;right:0;">
                    <li id="removeFile" style="display: flex; justify-content: center; align-items: center;cursor: pointer;">
                        <i class="fa fa-times" data-bs-toggle="tooltip" title="Remove the image!"></i>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Hidden field for ImageUrl -->
<input type="hidden" asp-for="Image" id="ImageUrlHiddenField" />
<script type="text/javascript">
    $(document).ready(function () {
        if ($('.select').length > 0) {
           $('.select').select2({
             minimumResultsForSearch: -1,
             width: '100%'
           });
        }
        $('#fileInput').on('change', function () {
            var file = this.files[0];
            if (file) {
                $('#fileName').text('File Name: ' + file.name);
                $('#fileSize').text('File Size: ' + (file.size / 1024).toFixed(2) + ' KB');
                $('#fileDetails').show();
                $('#imageuloadContainer').hide();
                $('#fileInput').hide();
            }
        });
        $('#removeFile').on('click', function () {
            $('#fileInput').val('');
            $('#fileDetails').hide();
            $('#imageuloadContainer').show();
            $('#fileInput').show();
        })
    });
</script>