@model InventoryEntity.Category.CategoryDto
@{
    ViewData["Title"] = "Add Brand";
}
<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Product Add Category</h4>
            <h6>Create new product Category</h6>
        </div>
    </div>
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <form asp-controller="Category" asp-action="Create" method="post" enctype="multipart/form-data" data-ajax="true">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    
                        <partial name="_CategoryFormFields" model="Model" />
                        <div class="col-lg-12">
                            <button type="submit" class="btn btn-submit me-2">Submit</button>
                        </div>
                   
                </div>
            </div>
        </div>
    </form>
</div>
    <script type="text/javascript">
        $(document).ready(function () {

        });

    </script>