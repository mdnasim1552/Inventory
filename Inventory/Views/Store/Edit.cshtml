@model InventoryEntity.Store.StoreDto
@{
    ViewData["Title"] = "Edit Store";
}
<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Store Edit</h4>
            <h6>Update your store</h6>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <form asp-controller="Store" asp-action="Edit" method="post" enctype="multipart/form-data" data-ajax="true">
        <div class="card">
            <div class="card-body">
                <div class="row">

                    <partial name="_StoreFormFields" model="Model" />
                    <!-- Hidden field for ImageUrl -->
                    @* <input type="hidden" asp-for="@Model.ImageUrl" id="ImageUrlHiddenField" /> *@
                    <div class="col-lg-12">
                        @* <a href="javascript:void(0);" class="btn btn-submit me-2">Submit</a> *@
                        <button type="submit" class="btn btn-submit me-2">Update</button>
                        <a class="btn btn-cancel" asp-action="Index">Cancel</a>
                    </div>

                </div>
            </div>
        </div>
    </form>
</div>
<script type="text/javascript">
    $(document).ready(function () {
       
    });

</script>
