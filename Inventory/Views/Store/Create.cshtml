@model InventoryEntity.Store.StoreDto
@{
    ViewData["Title"] = "Add Store";
}
<div class="content">
    <div class="page-header">
        <div class="page-title">
            <h4>Add Store</h4>
            <h6>Create new store</h6>
        </div>
    </div>

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <form asp-controller="Store" asp-action="Create" method="post" enctype="multipart/form-data" data-ajax="true">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    @await Html.PartialAsync("_StoreFormFields", Model)
                    <div class="col-lg-12">
                        <button type="submit" class="btn btn-submit me-2">Submit</button>
                    </div>

                </div>
            </div>
        </div>
    </form>
</div>
<script type="text/javascript">

    $(document).ready(function () {
        var updateMessage = '@TempData["CreatedMessage"]';
        if (updateMessage) {
            showContent(updateMessage);
        }
        if ($('.select').length > 0) {
            $('.select').select2({
                minimumResultsForSearch: -1,
                width: '100%'
            });
        }
    });
</script>