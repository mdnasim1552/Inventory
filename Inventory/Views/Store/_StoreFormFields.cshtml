@model InventoryEntity.Store.StoreDto
@{

}
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="Name">Store Name</label>
        <input asp-for="Name" type="text" />
    </div>
</div>
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="Code">Code</label>
        <input asp-for="Code" type="text" readonly="@(ViewBag.DisableInput == true ? "readonly" : null)">
    </div>
</div>
<div class="col-lg-9 col-12">
    <div class="form-group">
        <label asp-for="Address">Address</label>
        <input asp-for="Address" type="text">
    </div>
</div>
<div class="col-lg-3 col-sm-6 col-12">
    <div class="form-group">
        <label asp-for="Phone">Phone</label>
        <input asp-for="Phone" type="text">
    </div>
</div>
<script type="text/javascript">
    $(document).ready(function () {
        if ($('.select').length > 0) {
           $('.select').select2({
             minimumResultsForSearch: -1,
             width: '100%'
           });
        }
    });
</script>